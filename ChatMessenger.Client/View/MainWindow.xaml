<Window
    x:Class="ChatMessenger.Client.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    
    Title="ChatMessenger" Height="600" Width="410"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True"
    Style="{StaticResource MaterialDesignWindow}"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
            <DockPanel>
                <materialDesign:PackIcon Kind="Message" Width="24" Height="24" VerticalAlignment="Center"/>
                <TextBlock Margin="16,0,0,0" Text="CHAT MESSENGER" VerticalAlignment="Center" 
                           FontSize="18" FontWeight="Bold"/>
            </DockPanel>
        </materialDesign:ColorZone>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:Card Width="300" Padding="20" UniformCornerRadius="15">
                <StackPanel>
                    <TextBlock Text="LOGIN" HorizontalAlignment="Center" FontSize="24" 
                               FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                    <TextBox materialDesign:HintAssist.Hint="Email" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                    <PasswordBox materialDesign:HintAssist.Hint="Password" 
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Margin="0,10"/>

                    <Button Content="SIGN IN" Margin="0,20,0,0" Height="45" 
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            materialDesign:ButtonAssist.CornerRadius="10"/>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</Window>
