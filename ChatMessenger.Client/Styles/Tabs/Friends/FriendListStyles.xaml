<!-- FriendListView에서 사용되는 Style들을 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- 친구 추가, 검색 DockPanel -->
    <Style x:Key="FriendList_AddSearchPanel" TargetType="DockPanel">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="LastChildFill" Value="False"/>
        <Setter Property="Margin" Value="5,0,10,0"/>
    </Style>
    <!-- 친구 추가 Button -->
    <Style x:Key="FriendList_AddFriendButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconForegroundButton}">
        <Setter Property="Margin" Value="5,0"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="ToolTip" Value="친구 추가"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_FriendList_AddFriendIcon}"/>
    </Style>
    <!-- 친구 검색 TextBox -->
    <Style x:Key="FriendList_SearchFriendTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBoxBase}">
        <Setter Property="materialDesign:HintAssist.Hint" Value="Friend Search"/>
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="125"/>
        <Setter Property="Margin" Value="5,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ToolTip" Value="친구 검색"/>
        <Setter Property="CaretBrush" Value="{DynamicResource MaterialDesignBody}"/>
    </Style>

    <!-- ListBox 공통 Template -->
    <DataTemplate x:Key="FriendList_ProfileTemplate">
        <Grid Margin="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 프로필 Image 표시용 Grid -->
            <Grid Style="{StaticResource Common_ProfileImageGridInListBox}">
                <!-- Image를 원형으로 보이게해주는 Ellipse -->
                <Ellipse Style="{StaticResource Common_ProfileImageEllipse}"/>
                <materialDesign:PackIcon Style="{StaticResource MDStyle_DefaultProfileIcon}"/>
            </Grid>
            <!-- 그외 정보 표시용 Grid -->
            <Grid Grid.Column="1" Style="{StaticResource Common_InfoGridInListBox}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="{Binding Nickname}" Style="{StaticResource Common_InfoGrid_MainTextBlock}"/>
                    <materialDesign:PackIcon Style="{StaticResource MDStyle_Friend_FavoriteIcon}"
                                                       Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                <Grid Grid.Row="1" Margin="0,5,5,0">
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Common_InfoGrid_SubTextBlock}"/>
                </Grid>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>