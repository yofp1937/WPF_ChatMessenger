<!-- FriendDetailView에서 사용되는 Style들을 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:views="clr-namespace:ChatMessenger.Client.Views.Tabs.Friends"
    xmlns:vms="clr-namespace:ChatMessenger.Client.ViewModels.Tabs.Friends">
    <!-- FriendDetail Style -->
    <!-- 친구 추가 StackPanel Style -->
    <Style x:Key="FriendDetail_AddFriendStackPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Visibility" Value="{Binding IsAddFriendMode, Converter={StaticResource BoolToVis}}"/>
    </Style>
    <!-- 친구 추가 TextBox Style -->
    <Style x:Key="FriendDetail_AddFriendTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
        <Setter Property="materialDesign:HintAssist.Hint" Value="Enter Email to add friend"/>
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{DynamicResource MaterialDesignBody}"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Width" Value="180"/>
    </Style>
    <!-- 검색 Button Style -->
    <Style x:Key="FriendDetail_AddFriendSearchButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Content" Value="{StaticResource FriendDetail_SearchIcon}"/>
    </Style>
    <!-- 친구 추가 나가기 Button Style -->
    <Style x:Key="FriendDetail_AddFriendCloseButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFloatingActionButton}">
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Content" Value="{StaticResource FriendDetail_CloseIcon}"/>
    </Style>
    
    <!-- 우측 상단 더보기 탭 Style -->
    <Style x:Key="FriendDetail_SeeMorePopupBox" TargetType="materialDesign:PopupBox" BasedOn="{StaticResource MaterialDesignPopupBox}">
        <Setter Property="PlacementMode" Value="BottomAndAlignRightEdges"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Margin" Value="10,10"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Visibility" Value="{Binding CurrentFriend.IsMe, Converter={StaticResource InvertedBoolToHidden}}"/>
    </Style>

    <!-- 친구 정보 표시 StackPanel Style-->
    <Style x:Key="FriendDetail_InfoStackPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Visibility" Value="{Binding CurrentFriend, Converter={StaticResource NullToVisibilityConverter}}"/>
    </Style>
    <!-- ProfileImage 표시용 Grid -->
    <Style x:Key="FriendDetail_ProfileGrid" TargetType="Grid">
        <Setter Property="Width" Value="200"/>
        <Setter Property="Height" Value="200"/>
        <Setter Property="Margin" Value="0,20,0,20"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <!-- ProfileImage 변경용 Button -->
    <Style x:Key="FriendDetial_ProfileChangeButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFloatingActionMiniButton}">
        <Setter Property="Width" Value="35"/>
        <Setter Property="Height" Value="35"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="0,10,10,0"/>
        <Setter Property="Visibility" Value="{Binding CurrentFriend.IsMe, Converter={StaticResource BoolToVis}}"/>
        <Setter Property="ToolTip" Value="이미지 변경"/>
        <Setter Property="Content" Value="{StaticResource FriendDetail_ProfileChangeIcon}"/>
    </Style>
    
    <!-- 기본 정보 표시 StackPanel -->
    <Style x:Key="FriendDetail_Info_NicknameStackPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,20"/>
    </Style>
    <!-- 닉네임 표시용 TextBlock -->
    <Style x:Key="FriendDetail_Info_NicknameTextBlock" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Visibility" Value="{Binding IsEditMode, Converter={StaticResource InvertedBoolToColl}}"/>
    </Style>
    <!-- 이메일 표시용 TextBlock -->
    <Style x:Key="FriendDetail_Info_EmailTextBlock" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="5,0,0,0"/>
        <Setter Property="Visibility" Value="{Binding IsEditMode, Converter={StaticResource InvertedBoolToColl}}"/>
    </Style>
    <!-- 상태 메세지 표시용 TextBlock -->
    <Style x:Key="FriendDetail_Info_StatusMessageTextBlock" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Visibility" Value="{Binding IsEditMode, Converter={StaticResource InvertedBoolToColl}}"/>
    </Style>

    <!-- 내 프로필일때 최하단 수정 버튼 표시 Panel -->
    <Style x:Key="FriendDetail_EditButtonPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,25"/>
        <Setter Property="Visibility" Value="{Binding CurrentFriend.IsMe, Converter={StaticResource BoolToHidden}}"/>
    </Style>
</ResourceDictionary>