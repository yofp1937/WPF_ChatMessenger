<!-- ChatRoomView에서 사용되는 Style들을 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Header의 인원 표시용 TextBlock -->
    <Style x:Key="ChatRoom_PeopleCountTB" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,1,0,0"/>
    </Style>

    <!-- 채팅방 더보기 Button -->
    <Style x:Key="ChatRoom_SeeMoreBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Padding" Value="1"/>
        <Setter Property="Margin" Value="15"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Visibility" Value="{Binding IsSidePanelVisible, Converter={StaticResource InvertedBoolToColl}}"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_ChatRoom_MenuIcon}"/>
    </Style>
    
    <!-- 닉네임 표시용 TextBlock -->
    <Style x:Key="ChatRoom_NicknameTB" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Visibility" Value="{Binding IsMine, Converter={StaticResource InvertedBoolToColl}}"/>
    </Style>
    <!-- 내 메세지 표시용 StackPanel -->
    <Style x:Key="ChatRoom_MyMessageStackPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,8,5,0"/>
        <Setter Property="Visibility" Value="{Binding IsMine, Converter={StaticResource BoolToVis}}"/>
    </Style>
    <!-- 상대 메세지 표시용 StackPanel -->
    <Style x:Key="ChatRoom_OthersMessageStackPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="5,8,0,0"/>
        <Setter Property="Visibility" Value="{Binding IsMine, Converter={StaticResource InvertedBoolToColl}}"/>
    </Style>
    <!-- 메세지 내용 Border -->
    <Style x:Key="ChatRoom_MessageBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MaterialDesignBodyLight}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="MaxWidth" Value="500"/>
    </Style>
    <!-- 메세지 안읽은 사람 수 TextBlock -->
    <Style x:Key="ChatRoom_UnreadPeopleCountTB" TargetType="TextBlock">
        <Setter Property="Foreground" Value="Gold"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Visibility" Value="{Binding UnreadPeopleCount, Converter={StaticResource ZeroToVisibilityConverter}}"/>
    </Style>
    <!-- 메세지 전송 시간 TextBlock -->
    <Style x:Key="ChatRoom_SentAtTB" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
    </Style>
    
    
    <!-- 화면 하단 Input 영역 -->
    <!-- 채팅방 화면 닫기 Button -->
    <Style x:Key="ChatRoom_CloseRoomBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="1"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_ChatRoom_CloseRoomIcon}"/>
    </Style>
    <!-- 메세지 Input TextBox -->
    <Style x:Key="ChatRoom_InputTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="true"/>
        <Setter Property="Margin" Value="5,0,5,10"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <!-- 메세지 전송 Button -->
    <Style x:Key="ChatRoom_MessageSendBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_ChatRoom_SendMessageIcon}"/>
    </Style>
    
    <!-- 더보기 패널 영역 -->
    <!-- 더보기 패널 Border -->
    <Style x:Key="ChatRoom_SeeMorePanelBorder" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
        <Setter Property="Width" Value="250"/>
        <Setter Property="Visibility" Value="{Binding IsSidePanelVisible, Converter={StaticResource BoolToVis}}"/>
    </Style>
    <!-- 참여자 목록 TextBlock -->
    <Style x:Key="ChatRoom_ParticipantListTB" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- 더보기 패널 닫기 Button -->
    <Style x:Key="ChatRoom_CloseSeeMorePanelBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_ChatRoom_CloseSidePanelIcon}"/>
    </Style>
    <!-- 채팅방 나가기 Button -->
    <Style x:Key="ChatRoom_LeaveRoomBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_ChatRoom_ExitIcon}"/>
    </Style>
</ResourceDictionary>