<!-- ChatListView에서 사용되는 Style들을 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- 검색 TextBox -->
    <Style x:Key="ChatList_ChattingRoomSearchTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBoxBase}">
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="ToolTip" Value="채팅방 검색"/>
        <Setter Property="materialDesign:HintAssist.Hint" Value="Chatting Room Search"/>
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="true"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    
    <!-- ListBox Template -->
    <DataTemplate x:Key="ChatList_ChatRoomTemplate">
        <Grid Margin="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 채팅방 Image 표시용 Grid -->
            <Grid Style="{StaticResource Common_ProfileImageGridInListBox}">
                <!-- Image를 원형으로 보이게해주는 Ellipse -->
                <Ellipse Style="{StaticResource Common_ProfileImageEllipse}"/>
                <materialDesign:PackIcon Style="{StaticResource MDStyle_FriendList_ProfileDefaultIcon}"/>
            </Grid>
            <!-- 그외 정보 표시용 Grid -->
            <Grid Grid.Column="1" Style="{StaticResource Common_InfoGridInListBox}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical" Margin="0,10,0,5" VerticalAlignment="Center">
                    <!-- 채팅방 제목, 참가 인원수, 마지막 채팅 표시용 StackPanel -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource Common_InfoGrid_MainTextBlock}"/>
                        <TextBlock Text="{Binding ParticipiantCount}" FontSize="12" Margin="5,0" Foreground="Gold" VerticalAlignment="Center"
                                    Visibility="{Binding IsGroupChat, Converter={StaticResource BoolToHidden}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LastMessage}" Style="{StaticResource Common_InfoGrid_LastMessage}" Margin="0,5"/>
                </StackPanel>
                <!-- 마지막으로 보낸 메세지 시간 표시용 StackPanel -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,10,5,5" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastMessageSentAt, StringFormat={}{0:tt h:mm}}"
                                   Style="{StaticResource Common_InfoGrid_SubTextBlock}"/>
                    <!-- 안읽은 메세지 수 표시용 Grid -->
                    <Grid Margin="0,8,0,5" Visibility="{Binding UnreadCount, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter='Collapsed'}">
                        <Ellipse Fill="{DynamicResource MaterialDesign.Brush.Primary}" Width="25" Height="25"/>
                        <TextBlock Text="{Binding UnreadCount}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>