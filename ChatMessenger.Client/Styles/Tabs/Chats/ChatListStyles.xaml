<!-- ChatListView에서 사용되는 Style들을 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <Style x:Key="ChatList_ListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
        <Setter Property="Height" Value="80"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="ChatList_RoomListBox" TargetType="ListBox">
        <Setter Property="ItemContainerStyle" Value="{StaticResource ChatList_ListBoxItem}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="materialDesign:ScrollViewerAssist.IsAutoHideEnabled" Value="false" />
        <Setter Property="materialDesign:ListBoxAssist.IsToggle" Value="False" />
    </Style>
</ResourceDictionary>