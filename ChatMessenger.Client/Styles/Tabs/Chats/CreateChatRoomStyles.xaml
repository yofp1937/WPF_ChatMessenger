<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Title 수정용 TextBox -->
    <Style x:Key="CreateChatRoom_TitleTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True"/>
        <Setter Property="materialDesign:HintAssist.Hint" Value="Title"/>
        <Setter Property="MaxLength" Value="24"/>
        <Setter Property="materialDesign:TextFieldAssist.CharacterCounterVisibility" Value="Visible"/>
        <Setter Property="Width" Value="250"/>
        <Setter Property="IsEnabled" Value="{Binding IsTitleEditEnabled}"/>
    </Style>
    <!-- 초대할 참가자 수 표시용 TextBlock -->
    <Style x:Key="CreateChatRoom_InviteCountTB" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
    </Style>
</ResourceDictionary>