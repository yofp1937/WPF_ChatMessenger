<!-- 공통 사용되는 MaterialDesign Style들을 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:views="clr-namespace:ChatMessenger.Client.Views"
    xmlns:vms="clr-namespace:ChatMessenger.Client.ViewModels">

    <!-- materialDesign:Card의 기본 Style -->
    <Style x:Key="MDStyle_Card" TargetType="materialDesign:Card">
        <Setter Property="Width" Value="300"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="UniformCornerRadius" Value="15"/>
    </Style>
</ResourceDictionary>