<!-- MainWindow에서 사용하는 Style 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:views="clr-namespace:ChatMessenger.Client.Views"
    xmlns:vms="clr-namespace:ChatMessenger.Client.ViewModels">

    <!-- 메인 화면 전환 Style -->
    <DataTemplate DataType="{x:Type vms:LoginViewModel}">
        <views:LoginView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vms:RegisterViewModel}">
        <views:RegisterView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vms:MainShellViewModel}">
        <views:MainShellView />
    </DataTemplate>

    <!-- 최상단 타이틀바 Style -->
    <Style x:Key="MainTitleBarColorZone" TargetType="materialDesign:ColorZone">
        <Setter Property="Mode" Value="PrimaryMid"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
    </Style>
    <!-- 타이틀바 내부 아이콘 Style -->
    <Style x:Key="MainTitleBarPackIcon" TargetType="materialDesign:PackIcon">
        <Setter Property="Kind" Value="Message"/>
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- 타이틀바 내부 TextBlock의 Style -->
    <Style x:Key="MainTitleBarText" TargetType="TextBlock">
        <Setter Property="Margin" Value="10,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <!-- 타이틀바 내부 Button들의 Base Style -->
    <Style x:Key="MainTitleBarButtonBase" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="35"/>
        <Setter Property="Height" Value="35"/>
    </Style>
    <!-- 타이틀바 내부 Minimize Button Style -->
    <Style x:Key="MainTitleBarMinimizeButton" TargetType="Button" BasedOn="{StaticResource MainTitleBarButtonBase}">
        <Setter Property="Content" Value="{materialDesign:PackIcon Kind=WindowMinimize}"/>
        <Setter Property="ToolTip" Value="Minimize"/>
    </Style>
    <!-- 타이틀바 내부 Maximize Button Style -->
    <Style x:Key="MainTitleBarMaximizeButton" TargetType="Button" BasedOn="{StaticResource MainTitleBarButtonBase}">
        <Setter Property="Content" Value="{materialDesign:PackIcon Kind=WindowMaximize}"/>
        <Setter Property="ToolTip" Value="Maximize"/>
    </Style>
    <!-- 타이틀바 내부 Close Button Style -->
    <Style x:Key="MainTitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource MainTitleBarButtonBase}">
        <Setter Property="Content" Value="{materialDesign:PackIcon Kind=Close}"/>
        <Setter Property="ToolTip" Value="Close"/>
    </Style>
</ResourceDictionary>