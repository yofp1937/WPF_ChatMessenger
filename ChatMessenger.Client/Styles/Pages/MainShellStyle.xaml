<!-- MainShellView에서 사용되는 Style들을 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:chatViews="clr-namespace:ChatMessenger.Client.Views.Tabs.Chats"
    xmlns:chatVms="clr-namespace:ChatMessenger.Client.ViewModels.Tabs.Chats"
    xmlns:friendViews="clr-namespace:ChatMessenger.Client.Views.Tabs.Friends"
    xmlns:friendVms="clr-namespace:ChatMessenger.Client.ViewModels.Tabs.Friends"
    xmlns:settingsViews="clr-namespace:ChatMessenger.Client.Views.Tabs.Settings"
    xmlns:settingVms="clr-namespace:ChatMessenger.Client.ViewModels.Tabs.Settings">

    <!-- 화면 전환 Style -->
    <DataTemplate DataType="{x:Type friendVms:FriendListViewModel}">
        <friendViews:FriendListView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type friendVms:FriendDetailViewModel}">
        <friendViews:FriendDetailView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type chatVms:ChatListViewModel}">
        <chatViews:ChatListView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type chatVms:ChatRoomViewModel}">
        <chatViews:ChatRoomView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type chatVms:CreateChatRoomViewModel}">
        <chatViews:CreateChatRoomView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type settingVms:SettingListViewModel}">
        <settingsViews:SettingListView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type settingVms:SettingDetailViewModel}">
        <settingsViews:SettingDetailView/>
    </DataTemplate>

    <!-- 친구 추가 패널 -->
    <!-- 친구 추가 StackPanel Style -->
    <Style x:Key="MainShell_AddFriendStackPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Visibility" Value="{Binding IsAddFriendMode, Converter={StaticResource BoolToVis}}"/>
    </Style>
    <!-- 친구 추가 TextBox Style -->
    <Style x:Key="MainShell_AddFriendTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
        <Setter Property="materialDesign:HintAssist.Hint" Value="Enter Email to add friend"/>
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{DynamicResource MaterialDesignBody}"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Width" Value="180"/>
    </Style>
    <!-- 친구 추가 검색 Button Style -->
    <Style x:Key="MainShell_AddFriendSearchButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_FriendDetail_SearchIcon}"/>
    </Style>
    <!-- 친구 추가 나가기 Button Style -->
    <Style x:Key="MainShell_AddFriendCloseButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFloatingActionButton}">
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="5,5"/>
        <Setter Property="Content" Value="{StaticResource MDStyle_FriendDetail_CloseIcon}"/>
    </Style>

</ResourceDictionary>