<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:converters="clr-namespace:ChatMessenger.Client.Common.Converters">
    <!-- 사용할 Converter 선언 -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:BoolToHiddenConverter x:Key="BoolToHidden"/>
    <converters:InvertedBoolToCollapsedConverter x:Key="InvertedBoolToColl"/>
    <converters:InvertedBoolToHiddenConverter x:Key="InvertedBoolToHidden"/>
    <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    <converters:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter"/>
    <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
</ResourceDictionary>