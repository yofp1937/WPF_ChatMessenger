<!-- WindowViews에서 사용하는 Style 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:views="clr-namespace:ChatMessenger.Client.Views.Pages"
    xmlns:vms="clr-namespace:ChatMessenger.Client.ViewModels.Pages">

    <!-- MainWindowView의 메인 화면 전환 Style -->
    <DataTemplate DataType="{x:Type vms:LoginViewModel}">
        <views:LoginView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vms:RegisterViewModel}">
        <views:RegisterView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vms:MainShellViewModel}">
        <views:MainShellView />
    </DataTemplate>
</ResourceDictionary>