<!-- MainWindowView에서 사용하는 Style 정의하는곳 -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:views="clr-namespace:ChatMessenger.Client.Views.Pages"
    xmlns:vms="clr-namespace:ChatMessenger.Client.ViewModels.Pages">

    <Style x:Key="ChatMessengerCustomWindowStyle" TargetType="Window" BasedOn="{StaticResource MaterialDesignWindow}">
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <!-- Window 창 통제 기능은 WindowControlService에 구현했으므로 CaptionHeight를 0으로 설정 -->
                <!-- GlassFrameThickness: 윈도우 표준 테두리 두께 (0으로 하면 그림자도 안쓰겠다는 뜻) -->
                <!-- UseAeroCaptionButtons: Window에서 기본 제공해주는 최소화, 최대화, 닫기 버튼 보여줄지 여부 -->
                <WindowChrome ResizeBorderThickness="5" CornerRadius="0" CaptionHeight="0"
                                        GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MainWindowView의 메인 화면 전환 Style -->
    <DataTemplate DataType="{x:Type vms:LoginViewModel}">
        <views:LoginView/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vms:RegisterViewModel}">
        <views:RegisterView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vms:MainShellViewModel}">
        <views:MainShellView />
    </DataTemplate>
</ResourceDictionary>