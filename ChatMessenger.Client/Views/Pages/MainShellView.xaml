<UserControl
    x:Class="ChatMessenger.Client.Views.Pages.MainShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- 화면 전체 Grid -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽 화면 -->
        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0" SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ContentControl Content="{Binding CurrentViewModel.LeftContentViewModel}"/>
                <!-- 하단 화면 네비게이션 -->
                <materialDesign:ColorZone Grid.Row="1" Mode="Standard" Padding="0"
                                                materialDesign:ElevationAssist.Elevation="Dp8">
                    <UniformGrid Columns="3">
                        <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" Height="50" IsChecked="True"
                                           Content="{materialDesign:PackIcon Kind=AccountGroup}" ToolTip="친구 목록"/>
                        <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" Height="50"
                                           Content="{materialDesign:PackIcon Kind=Chat}" ToolTip="채팅 목록"/>
                        <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" Height="50"
                                           Content="{materialDesign:PackIcon Kind=Settings}" ToolTip="설정"/>
                    </UniformGrid>
                </materialDesign:ColorZone>
            </Grid>
        </Border>

        <!-- 오른쪽 화면 -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel.RightContentViewModel}"/>
    </Grid>
</UserControl>