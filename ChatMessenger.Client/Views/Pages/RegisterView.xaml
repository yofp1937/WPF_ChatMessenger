<UserControl
    x:Class="ChatMessenger.Client.Views.Pages.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:converters="clr-namespace:ChatMessenger.Client.Common.Converters">
    
    <UserControl.Resources>
        <converters:MultiBindingConverter x:Key="MultiBindingConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:Card Style="{StaticResource MDStyle_Card}">
                <StackPanel>
                    <Grid>
                        <Button ToolTip="Back to Login" Style="{StaticResource Auth_GoBackButton}"
                                    Command="{Binding MoveToLoginCommand}"/>
                        <TextBlock Text="Register" Style="{StaticResource Auth_TitleTextBlcok}"/>
                    </Grid>

                    <TextBox Text="{Binding Email}" Style="{StaticResource Auth_EmailTextBox}"/>
                    
                    <TextBox Text="{Binding Nickname}" Style="{StaticResource Auth_NicknameTextBox}"/>

                    <PasswordBox x:Name="PasswordInput" Style="{StaticResource Auth_PasswordBox}"/>

                    <PasswordBox x:Name="PasswordInputCheck" Style="{StaticResource Auth_PasswordBox}"
                                        materialDesign:HintAssist.Hint="Confirm Password"/>

                    <TextBlock Text="{Binding WarningText}" Style="{StaticResource Common_WarningTextBlock}"/>

                    <Button Content="Create Acount" Style="{StaticResource Auth_RequestButton}"
                                Command="{Binding RegisterCommand}">
                        <Button.CommandParameter>
                            <MultiBinding Converter="{StaticResource MultiBindingConverter}">
                                <Binding ElementName="PasswordInput"/>
                                <Binding ElementName="PasswordInputCheck"/>
                            </MultiBinding>
                        </Button.CommandParameter>
                    </Button>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</UserControl>