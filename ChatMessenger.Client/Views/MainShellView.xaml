<UserControl
    x:Class="ChatMessenger.Client.Views.MainShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Width="500" Height="300" Background="DimGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.45*" />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="로그인 되셨습니다"/>
            <Button Content="로그아웃"/>
        </StackPanel>
        
        <GridSplitter Grid.Column="1" Width="1" Background="Red" HorizontalAlignment="Center"/>

        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="채팅창 구역"/>
        </StackPanel>
        
    </Grid>
</UserControl>