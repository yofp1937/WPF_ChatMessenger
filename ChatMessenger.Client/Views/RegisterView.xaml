<UserControl
    x:Class="ChatMessenger.Client.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:Card Width="300" Padding="20" UniformCornerRadius="15">
                <StackPanel>
                    <TextBlock Text="회원가입" HorizontalAlignment="Center" FontSize="24" 
                               FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                    <TextBox materialDesign:HintAssist.Hint="Email" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,10"/>

                    <PasswordBox materialDesign:HintAssist.Hint="Password" 
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Margin="0,10"/>
                    
                    <PasswordBox materialDesign:HintAssist.Hint="Confirm Password" 
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}" Margin="0,10"/>

                    <Button Content="SIGN IN" Margin="0,20,0,0" Height="45" 
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            materialDesign:ButtonAssist.CornerRadius="10"/>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</UserControl>