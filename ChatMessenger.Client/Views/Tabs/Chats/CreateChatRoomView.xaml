<UserControl
    x:Class="ChatMessenger.Client.Views.Tabs.Chats.CreateChatRoomView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- 상단 메인 Grid -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 왼쪽 프로필 이미지, Title Input Panel -->
            <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="15,40,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- 프로필 이미지 -->
                <Grid Style="{StaticResource Common_BigProfileGrid}">
                    <!-- Image를 원형으로 보이게해주는 Ellipse -->
                    <Ellipse Style="{StaticResource Common_ProfileImageEllipse}"/>
                    <materialDesign:PackIcon Style="{StaticResource MDStyle_Chat_BigGroupChatIcon}"/>
                    <!-- 프로필 이미지 수정 Button -->
                    <Button Style="{StaticResource Common_ProfileChangeButton}"/>
                </Grid>
                <!-- Title 수정 TextBox -->
                <StackPanel Grid.Row="1">
                    <TextBox Text="{Binding RoomTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CreateChatRoom_TitleTextBox}"/>
                    <TextBlock Text="{Binding WarningText}" Style="{StaticResource Common_WarningTextBlock}"
                                   Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
            
            <!-- 오른쪽 초대할 친구 List Panel -->
            <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="15">
                <ListBox ItemsSource="{Binding FriendList}" Background="Transparent" BorderThickness="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Multiple">
                    <!-- 핵심: ListBoxItem(박스 전체)의 선택 상태를 모델의 IsSelected와 연결 -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <!-- 참여자 한 명씩 그리는 템플릿 -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" IsHitTestVisible="false"/>
                                <!-- 프로필 이미지 표시용 Grid -->
                                <Grid Grid.Column="1" Style="{StaticResource Common_ProfileImageGridInListBox}" HorizontalAlignment="Left">
                                    <!-- Image를 원형으로 보이게해주는 Ellipse -->
                                    <Ellipse Style="{StaticResource Common_ProfileImageEllipse}"/>
                                    <materialDesign:PackIcon Style="{StaticResource MDStyle_DefaultProfileIcon}"/>
                                </Grid>
                                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Nickname}"/>
                                    <TextBlock Text="{Binding Email, StringFormat='({0})'}" Margin="2,3,0,0" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
        
        <!-- 하단 버튼 Grid -->
        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Command="{Binding CreateChatRoomCommand}" Content="초대" Margin="10"/>
                <Button Content="취소" Margin="10"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>