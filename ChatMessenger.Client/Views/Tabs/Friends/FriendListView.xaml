<UserControl
    x:Class="ChatMessenger.Client.Views.Tabs.Friends.FriendListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <!-- мҷјмӘҪ Grid мҳҒм—ӯ-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- лӮҙ н”„лЎңн•„: FriendResponse нҳ•мӢқмқҳлӢЁмқј лҚ°мқҙн„°лҘј Binding н•ҳкі мһҲкё°л•Ңл¬ём—җ ContentлҘј м„Өм • -->
        <ListBox x:Name="MyProfileListBox" Style="{StaticResource FriendList_ListBox}"
                    SelectedValue="{Binding SelectedFriend, Mode=TwoWay}" SelectedValuePath="Content"
                    PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown">
            <ListBoxItem Content="{Binding UserProfile}">
                <ListBoxItem.ContentTemplate>
                    <DataTemplate>
                        <Grid Style="{StaticResource MainShell_LeftPanel_ProfileGrid}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Image н‘ңмӢңмҡ© Grid -->
                            <Grid Style="{StaticResource ProfileGrid_ProfileImageGrid}">
                                <!-- ImageлҘј мӣҗнҳ•мңјлЎң ліҙмқҙкІҢн•ҙмЈјлҠ” Ellipse -->
                                <Ellipse Style="{StaticResource ProfileGrid_ProfileImageEllipse}"/>
                                <materialDesign:PackIcon Style="{StaticResource ProfileGrid_ProfileImageIcon}"/>
                            </Grid>
                            <!-- Nicknameкіј StatusMessage н‘ңмӢңмҡ© DockPanel -->
                            <StackPanel Grid.Column="1" Style="{StaticResource ProfileGrid_InfoStackPanel}">
                                <TextBlock Text="{Binding Nickname}" Style="{StaticResource ProfileGrid_InfoStackPanel_NicknameTextBlock}"/>
                                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource ProfileGrid_InfoStackPanel_StatusMessageTextBlock}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBoxItem.ContentTemplate>
            </ListBoxItem>
        </ListBox>

        <Separator Grid.Row="1" VerticalAlignment="Top" Margin="20,0"
                   Background="{DynamicResource MaterialDesignDivider}"/>

        <!-- м№ңкө¬ лӘ©лЎқ: ObservableCollection нҳ•мӢқмқҳ лҚ°мқҙн„°лҘј Binding н•ҳкі мһҲкё°л•Ңл¬ём—җ ItemSourceлҘј м„Өм • -->
        <ListBox Grid.Row="2" x:Name="FriendsListBox" Style="{StaticResource FriendList_ListBox}"
                    SelectedItem="{Binding SelectedFriend, Mode=TwoWay}" ItemsSource="{Binding Friends}"
                    PreviewMouseLeftButtonDown="ListBox_PreviewMouseLeftButtonDown">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Style="{StaticResource MainShell_LeftPanel_ProfileGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Image н‘ңмӢңмҡ© Grid -->
                        <Grid Style="{StaticResource ProfileGrid_ProfileImageGrid}">
                            <!-- ImageлҘј мӣҗнҳ•мңјлЎң ліҙмқҙкІҢн•ҙмЈјлҠ” Ellipse -->
                            <Ellipse Style="{StaticResource ProfileGrid_ProfileImageEllipse}"/>
                            <materialDesign:PackIcon Style="{StaticResource ProfileGrid_ProfileImageIcon}"/>
                        </Grid>
                        <!-- Nicknameкіј StatusMessage н‘ңмӢңмҡ© DockPanel -->
                        <StackPanel Grid.Column="1" Style="{StaticResource ProfileGrid_InfoStackPanel}">
                            <TextBlock Text="{Binding Nickname}" Style="{StaticResource ProfileGrid_InfoStackPanel_NicknameTextBlock}"/>
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource ProfileGrid_InfoStackPanel_StatusMessageTextBlock}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>